{
    "$schema": "https://json-schema.org/schema",
    "$id": "create",
    "title": "",
    "type": "object",
    "properties": {
        "path": {
            "type": "string",
            "description": "Path to migrations folder",
            "$default": {
                "$source": "argv",
                "index": 0
            },
            "x-prompt": "What path would you like to use?"
        },
        "name": {
            "type": "string",
            "description": "The name of migration",
            "$default": {
                "$source": "argv",
                "index": 1
            },
            "x-prompt": "What name would you like to use?"
        }
    },
    "required": ["path", "name"]
}
